{
  "name": "@kaiketsu/smoke-gate",
  "version": "0.1.0",
  "description": "CI gate que bate todos os endpoints HTTP contra um DB real e bloqueia o deploy se algum retornar 500. Pega drift entre código SQL e schema antes da prod.",
  "type": "module",
  "main": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js"
    },
    "./pg": {
      "types": "./dist/db/pg.d.ts",
      "import": "./dist/db/pg.js"
    },
    "./mocks": {
      "types": "./dist/mocks/auth.d.ts",
      "import": "./dist/mocks/auth.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "import": "./dist/vitest.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "smoke-test",
    "ci",
    "integration-test",
    "express",
    "postgres",
    "drift-detection"
  ],
  "author": "Reimon Gonçalves",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reimon/smoke-gate.git"
  },
  "peerDependencies": {
    "supertest": ">=6",
    "pg": ">=8",
    "vitest": ">=1"
  },
  "peerDependenciesMeta": {
    "supertest": { "optional": true },
    "pg": { "optional": true },
    "vitest": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8",
    "@types/supertest": "^6",
    "pg": "^8.13.0",
    "supertest": "^7.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
